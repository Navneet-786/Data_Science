import matplotlib.pyplot as plt
import numpy as np
movies = [
    "Titanic",
    "The Lord of the Rings: The Return of the King",
    "Forrest Gump",
    "Gladiator",
    "Parasite",
    "Oppenheimer"
]
years = [2001 , 2002 , 2003 , 2004 , 2005 , 2006]
revenues1 = [2.26,1.15, 0.678, 0.465, 0.262, 0.952]

# plot the bar graph to show which year vs revenue
plt.bar(years, revenues1)
plt.xlabel("Years")
plt.ylabel("revenue")
plt.title("Oscar Winning Movies Revenue(in cr) in given Years")

rng = np.arange(len(years))

for i in rng:
    plt.text(years[i], revenues1[i]+ 0.069 ,str(revenues1[i]),ha="center",rotation=45)
plt.ylim(0, max(revenues1)+0.5)
plt.xlim(min(years)-1, max(years)+1)



