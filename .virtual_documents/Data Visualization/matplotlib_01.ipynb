import numpy as np

np.random.seed(12)
marks = np.random.normal(65, 10, 40)
marks = np.clip(marks, 20, 100)

bins = np.arange(10, 101,10, dtype="int64")

arr = plt.hist(marks, color="purple", edgecolor="white", bins=bins)
