


import requests
from bs4 import BeautifulSoup
import pandas as pd


total_pages = 50
pages = list(range(1,total_pages + 1))

headers = {
    "User-Agent":"Mozilla/5.0 (Linux; Android 6.0; Nexus 5 Build/MRA58N) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/145.0.0.0 Mobile Safari/537.36"
}

all_books = []
for page in pages:
    url = f"https://books.toscrape.com/catalogue/page-{page}.html"
    res = requests.get(url,headers=headers)
    
    soup = BeautifulSoup(res.text, 'lxml')
    articles = soup.find_all('article', class_='product_pod')
    for article in articles:
        book_name = article.find("h3").find("a").get_text().strip()  #print(article.select("h3 a")
        price = article.select(".product_price")[0].select('.price_color')[0].get_text().strip()
        availability = article.select(".product_price")[0].select(".instock")[0].get_text().strip()

        all_books.append([book_name, price, availability])
        

column_names = ["Book Name", "Price", "Status"]
df = pd.DataFrame(all_books, columns = column_names)




df
